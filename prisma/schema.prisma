generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  DELETED
}

enum ProjectMemberRole {
  OWNER
  EDITOR
  VIEWER
}

enum ScheduleCategory {
  MEETING
  VENUE
  STUDIO
  DRESS
  MAKEUP
  INVITATION
  VIDEO
  PAYMENT
  TODO
}

enum TemplateType {
  INVITATION
  VIDEO
}

enum TemplateTier {
  FREE
  PREMIUM
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  FONT
  OTHER
}

enum MediaVisibility {
  PRIVATE
  PUBLIC
}

enum VideoSceneType {
  INTRO
  PHOTO
  TEXT
  GALLERY
  OUTRO
}

enum RenderJobStatus {
  QUEUED
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
}

enum InvitationStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
  ARCHIVED
}

enum AttendanceStatus {
  ATTENDING
  NOT_ATTENDING
  UNDECIDED
}

enum GuestSide {
  GROOM
  BRIDE
  BOTH
  UNKNOWN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(USER)

  projects      WeddingProject[]
  memberships   ProjectMember[]
  mediaAssets   MediaAsset[]
  renderJobs    RenderJob[]
  accounts      Account[]
  sessions      Session[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@index([role])
  @@index([createdAt])
  @@index([deletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WeddingProject {
  id                  String        @id @default(cuid())
  ownerId             String
  title               String
  slug                String?
  status              ProjectStatus @default(DRAFT)

  groomName           String
  brideName           String
  weddingDate         DateTime?
  venueName           String?
  venueAddress        String?
  memo                String?       @db.Text

  owner               User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members             ProjectMember[]
  videoProject        VideoProject?
  invitationProject   InvitationProject?
  mediaAssets         MediaAsset[]
  renderJobs          RenderJob[]
  scheduleEvents      ProjectScheduleEvent[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@unique([ownerId, slug])
  @@index([ownerId, status])
  @@index([weddingDate])
  @@index([deletedAt])
}

model ProjectScheduleEvent {
  id                String           @id @default(cuid())
  weddingProjectId  String
  title             String
  description       String?          @db.Text
  category          ScheduleCategory @default(TODO)
  startsAt          DateTime
  endsAt            DateTime?
  isAllDay          Boolean          @default(false)
  isCompleted       Boolean          @default(false)
  sortOrder         Int              @default(0)

  weddingProject    WeddingProject   @relation(fields: [weddingProjectId], references: [id], onDelete: Cascade)

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  @@index([weddingProjectId, startsAt])
  @@index([weddingProjectId, isCompleted])
  @@index([deletedAt])
}

model ProjectMember {
  id         String            @id @default(cuid())
  projectId  String
  userId     String
  role       ProjectMemberRole @default(EDITOR)

  project    WeddingProject    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deletedAt  DateTime?

  @@unique([projectId, userId])
  @@index([userId])
  @@index([deletedAt])
}

model Template {
  id                  String              @id @default(cuid())
  type                TemplateType
  tier                TemplateTier        @default(FREE)
  key                 String              @unique
  name                String
  description         String?             @db.Text
  thumbnailUrl        String?
  previewUrl          String?
  config              Json
  isActive            Boolean             @default(true)
  sortOrder           Int                 @default(0)

  videoProjects       VideoProject[]
  invitationProjects  InvitationProject[]

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?

  @@index([type, tier, isActive])
  @@index([sortOrder])
  @@index([deletedAt])
}

model VideoProject {
  id                  String          @id @default(cuid())
  weddingProjectId    String          @unique
  templateId          String?
  title               String
  durationSeconds     Int             @default(60)
  width               Int             @default(1920)
  height              Int             @default(1080)
  fps                 Int             @default(30)
  musicAssetId        String?
  config              Json?

  weddingProject      WeddingProject  @relation(fields: [weddingProjectId], references: [id], onDelete: Cascade)
  template            Template?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  musicAsset          MediaAsset?     @relation("VideoMusicAsset", fields: [musicAssetId], references: [id], onDelete: SetNull)
  scenes              VideoScene[]
  lyricSegments       LyricSegment[]
  renderJobs          RenderJob[]

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?

  @@index([templateId])
  @@index([musicAssetId])
  @@index([deletedAt])
}

model InvitationProject {
  id                  String            @id @default(cuid())
  weddingProjectId    String            @unique
  templateId          String?
  status              InvitationStatus  @default(DRAFT)
  publicSlug          String            @unique
  publishedAt         DateTime?

  title               String
  greeting            String?           @db.Text
  groomFatherName     String?
  groomMotherName     String?
  brideFatherName     String?
  brideMotherName     String?
  contactPhoneGroom   String?
  contactPhoneBride   String?
  eventDate           DateTime?
  venueName           String?
  venueAddress        String?
  venueDetail         String?
  mapProvider         String?
  mapLat              Decimal?          @db.Decimal(10, 7)
  mapLng              Decimal?          @db.Decimal(10, 7)

  coverAssetId        String?
  gallery             Json?
  rsvpEnabled         Boolean           @default(true)
  guestbookEnabled    Boolean           @default(true)
  config              Json?

  weddingProject      WeddingProject    @relation(fields: [weddingProjectId], references: [id], onDelete: Cascade)
  template            Template?         @relation(fields: [templateId], references: [id], onDelete: SetNull)
  coverAsset          MediaAsset?       @relation("InvitationCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)
  rsvps               RSVP[]
  guestbookEntries    Guestbook[]

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?

  @@index([status, publishedAt])
  @@index([templateId])
  @@index([coverAssetId])
  @@index([deletedAt])
}

model MediaAsset {
  id                    String              @id @default(cuid())
  ownerId               String
  weddingProjectId      String?
  type                  MediaType
  visibility            MediaVisibility     @default(PRIVATE)
  storageKey            String              @unique
  bucket                String
  url                   String?
  fileName              String
  contentType           String
  sizeBytes             BigInt
  width                 Int?
  height                Int?
  durationSeconds       Float?
  altText               String?
  metadata              Json?

  owner                 User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  weddingProject        WeddingProject?     @relation(fields: [weddingProjectId], references: [id], onDelete: Cascade)
  videoMusicProjects    VideoProject[]      @relation("VideoMusicAsset")
  invitationCovers      InvitationProject[] @relation("InvitationCoverAsset")
  videoScenes           VideoScene[]
  renderJobOutputs      RenderJob[]         @relation("RenderOutputAsset")

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?

  @@index([ownerId, type])
  @@index([weddingProjectId, type])
  @@index([visibility])
  @@index([deletedAt])
}

model VideoScene {
  id               String         @id @default(cuid())
  videoProjectId   String
  mediaAssetId     String?
  type             VideoSceneType @default(PHOTO)
  order            Int
  startMs          Int
  durationMs       Int
  title            String?
  subtitle         String?
  body             String?        @db.Text
  transition       String?
  config           Json?

  videoProject     VideoProject   @relation(fields: [videoProjectId], references: [id], onDelete: Cascade)
  mediaAsset       MediaAsset?    @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  @@unique([videoProjectId, order])
  @@index([videoProjectId, startMs])
  @@index([mediaAssetId])
  @@index([deletedAt])
}

model LyricSegment {
  id              String       @id @default(cuid())
  videoProjectId  String
  order           Int
  startMs         Int
  endMs           Int
  text            String       @db.Text
  style           Json?

  videoProject    VideoProject @relation(fields: [videoProjectId], references: [id], onDelete: Cascade)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  @@unique([videoProjectId, order])
  @@index([videoProjectId, startMs])
  @@index([deletedAt])
}

model RenderJob {
  id                String          @id @default(cuid())
  userId            String
  weddingProjectId  String
  videoProjectId    String
  outputAssetId     String?
  status            RenderJobStatus @default(QUEUED)
  queueJobId         String?         @unique
  progress           Int             @default(0)
  attempts           Int             @default(0)
  maxAttempts        Int             @default(3)
  input              Json
  errorMessage       String?         @db.Text
  startedAt          DateTime?
  finishedAt         DateTime?

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  weddingProject    WeddingProject  @relation(fields: [weddingProjectId], references: [id], onDelete: Cascade)
  videoProject      VideoProject    @relation(fields: [videoProjectId], references: [id], onDelete: Cascade)
  outputAsset       MediaAsset?     @relation("RenderOutputAsset", fields: [outputAssetId], references: [id], onDelete: SetNull)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  @@index([userId, status])
  @@index([weddingProjectId, status])
  @@index([videoProjectId, status])
  @@index([createdAt])
  @@index([deletedAt])
}

model RSVP {
  id                    String           @id @default(cuid())
  invitationProjectId   String
  name                  String
  phone                 String?
  side                  GuestSide        @default(UNKNOWN)
  attendance            AttendanceStatus @default(UNDECIDED)
  guestCount            Int              @default(1)
  mealOption            String?
  message               String?          @db.Text
  privacyConsent        Boolean          @default(false)
  ipAddress             String?

  invitationProject     InvitationProject @relation(fields: [invitationProjectId], references: [id], onDelete: Cascade)

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  deletedAt             DateTime?

  @@index([invitationProjectId, attendance])
  @@index([createdAt])
  @@index([deletedAt])
}

model Guestbook {
  id                  String            @id @default(cuid())
  invitationProjectId String
  name                String
  passwordHash        String?
  message             String            @db.Text
  isPrivate           Boolean           @default(false)
  isHidden            Boolean           @default(false)
  ipAddress           String?

  invitationProject   InvitationProject @relation(fields: [invitationProjectId], references: [id], onDelete: Cascade)

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?

  @@index([invitationProjectId, isHidden])
  @@index([createdAt])
  @@index([deletedAt])
}
